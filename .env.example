# Absolute host paths to files outside this repository. Each file must exist and use mode 0600.
# Only the AI API key file may be empty; it must still exist for Compose to mount it.
PORTFOLIO_POSTGRES_PASSWORD_SECRET_FILE=/absolute/path/to/portfolio-secrets/postgres_password
PORTFOLIO_POSTGRES_APP_PASSWORD_SECRET_FILE=/absolute/path/to/portfolio-secrets/postgres_app_password
PORTFOLIO_ADMIN_PASSWORD_HASH_SECRET_FILE=/absolute/path/to/portfolio-secrets/blog_admin_password_hash
PORTFOLIO_APP_SECRET_KEY_SECRET_FILE=/absolute/path/to/portfolio-secrets/app_secret_key
PORTFOLIO_AI_API_KEY_SECRET_FILE=/absolute/path/to/portfolio-secrets/ai_api_key

# Host-side backup signing keys. Keep both files outside this repository and
# every backup root. The private key must be mode 0600; public keys may be 0600
# or 0644. The plural variable is a colon-separated rotation keyring used by
# verify, restore, and production_probe.
PORTFOLIO_BACKUP_PRIVATE_KEY_FILE=/absolute/path/to/portfolio-backup-keys/private.pem
PORTFOLIO_BACKUP_PUBLIC_KEY_FILE=/absolute/path/to/portfolio-backup-keys/public.pem
PORTFOLIO_BACKUP_PUBLIC_KEY_FILES=/absolute/path/to/portfolio-backup-keys/public.pem
# Optional DeepSeek model override. Defaults to the low-latency production model.
AI_MODEL=deepseek-v4-flash

# Public AI endpoint guardrails. The body limit is fixed to the edge limit.
TRUST_PROXY_HOPS=1
AGENT_MAX_BODY_BYTES=65536
# Messages, user-message characters, and history characters cannot be below
# the browser contract. Assistant messages cannot exceed 10500 characters, so
# one complete reply and the next 1500-character user message fit in history.
AGENT_MAX_MESSAGES=12
AGENT_MAX_MESSAGE_CHARS=4000
AGENT_MAX_USER_MESSAGE_CHARS=1500
AGENT_MAX_HISTORY_CHARS=12000
AGENT_MAX_OUTPUT_TOKENS=512
AGENT_UPSTREAM_TIMEOUT_MS=15000
AGENT_MAX_CONCURRENT_REQUESTS=2
AGENT_RATE_WINDOW_MS=60000
AGENT_RATE_REQUESTS=6
AGENT_DAILY_REQUESTS_PER_IP=40
AGENT_GLOBAL_DAILY_REQUESTS=500
AGENT_MAX_TRACKED_IPS=10000

# Server-rendered public content. The response limit cannot be lower than the
# backend's 2 MiB content ceiling; fetch timeout cannot exceed 20 seconds.
CMS_FETCH_TIMEOUT_MS=3000
CMS_CONTENT_LIMIT_BYTES=3145728
CMS_CACHE_TTL_MS=30000
CMS_STALE_TTL_MS=300000
# May only be reduced; this reserves 2 seconds within the 20-second stop grace period.
SHUTDOWN_TIMEOUT_MS=18000

# PostgreSQL maintenance owner and least-privilege request role.
POSTGRES_USER=portfolio
POSTGRES_APP_USER=portfolio_app
POSTGRES_DB=portfolio_cms
# Runtime connect + pool + statement budgets must total at most 25 seconds.
# Migrations get a separate longer statement budget outside the request path.
DB_CONNECT_TIMEOUT_SECONDS=3
DB_POOL_TIMEOUT_SECONDS=3
DB_STATEMENT_TIMEOUT_MS=4000
DB_MIGRATION_STATEMENT_TIMEOUT_MS=120000
ADMIN_WRITES_ENABLED=true
API_DOCS_ENABLED=false
ALLOWED_HOSTS=beta-demo.top,localhost,127.0.0.1,backend

AUTH_COOKIE_SECURE=true
AUTH_SESSION_HOURS=12
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_WINDOW_SECONDS=900
ADMIN_LOGIN_LOCKOUT_SECONDS=900
ADMIN_LOGIN_MAX_CLIENTS=10000
# Only addresses of reverse proxies that overwrite X-Real-IP belong here.
AUTH_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128,172.16.0.0/12
# Browser admin writes must originate here. Use scheme + host only, without a path.
PUBLIC_ORIGIN=https://beta-demo.top
# Optional comma-separated additional exact origins, normally left empty.
CSRF_TRUSTED_ORIGINS=
# Optional container path to a private healthcheck CA. Leave empty for public TLS.
NGINX_HEALTH_CA_FILE=
# May only be reduced; the backend rejects values above 8 MiB.
MAX_UPLOAD_MB=8
# Hard cap for entries in the managed upload inventory.
MAX_MEDIA_FILES=1000
# CPU/disk-heavy upload workers per backend process; additional uploads wait.
MAX_CONCURRENT_UPLOADS=2
MAX_IMAGE_PIXELS=40000000
MAX_IMAGE_DIMENSION=12000
MAX_IMAGE_FRAMES=200
MAX_IMAGE_TOTAL_PIXELS=80000000
# May only be reduced; the backend rejects values above 2097152 bytes.
MAX_CONTENT_BYTES=2097152
# May only be reduced; 100 full-size revisions already represent a large storage budget.
MAX_CONTENT_REVISIONS=100
