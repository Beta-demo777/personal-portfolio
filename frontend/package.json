{
  "name": "personal-portfolio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "tsx server-entry.ts",
    "build": "npm run clean && vite build && esbuild server-entry.ts --bundle --platform=node --format=esm --packages=external --outfile=server-dist/server.mjs",
    "start": "node server-dist/server.mjs",
    "test": "npm run test:unit && npm run test:server && npm run test:smoke",
    "test:unit": "vitest run",
    "test:server": "node --import tsx --test server/*.test.ts",
    "test:smoke": "npm run build && node --import tsx --test server/*.smoke.ts",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "preview": "vite preview",
    "clean": "rm -rf dist server-dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.13.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
