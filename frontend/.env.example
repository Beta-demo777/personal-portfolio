# Optional absolute path for local server development. Production Compose uses
# its isolated /run/secrets projection; never store the key in an env file.
GEMINI_API_KEY_FILE=/absolute/path/to/portfolio-secrets/gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Public SSR origin and direct CMS origin for local development. The response
# limit cannot be lower than 2 MiB; fetch timeout cannot exceed 20 seconds.
PUBLIC_ORIGIN=http://localhost:3000
CMS_INTERNAL_ORIGIN=http://127.0.0.1:8000
CMS_FETCH_TIMEOUT_MS=3000
CMS_CONTENT_LIMIT_BYTES=3145728
CMS_CACHE_TTL_MS=30000
CMS_STALE_TTL_MS=300000

# Direct local development has no trusted proxy. Production Compose sets this to 1.
TRUST_PROXY_HOPS=0

# Public AI endpoint resource and cost limits. The body limit is fixed to the
# edge contract. Messages, user-message characters, and history characters
# cannot be below the browser contract; assistant messages cannot exceed 10500
# so the previous reply and next maximum-size user message both remain in history.
AGENT_MAX_BODY_BYTES=65536
AGENT_MAX_MESSAGES=12
AGENT_MAX_MESSAGE_CHARS=4000
AGENT_MAX_USER_MESSAGE_CHARS=1500
AGENT_MAX_HISTORY_CHARS=12000
AGENT_MAX_OUTPUT_TOKENS=512
AGENT_UPSTREAM_TIMEOUT_MS=15000
AGENT_MAX_CONCURRENT_REQUESTS=2
AGENT_RATE_WINDOW_MS=60000
AGENT_RATE_REQUESTS=6
AGENT_DAILY_REQUESTS_PER_IP=40
AGENT_GLOBAL_DAILY_REQUESTS=500
AGENT_MAX_TRACKED_IPS=10000
